								],
								"type": "text/javascript",
								"packages": {}
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Register Tenant - status is 201\", function () {\r",
									"  pm.response.to.have.status(201);\r",
									"});\r",
									"const response = pm.response.json();\r",
									"pm.test(\"Register Tenant - response success is true\", function () {\r",
									"  pm.expect(response.success).to.eql(true);\r",
									"});\r",
									"if (response?.data?.token) {\r",
									"  pm.environment.set(\"token\", response.data.token);\r",
									"}\r",
									"console.log(\"Token saved:\", pm.environment.get(\"token\"));\r",
									""
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
